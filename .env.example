# Fallback AI key, used only if no key has been saved via the in-app Settings page (/settings).
# Without this set AND no key saved in Settings, the app runs fully in manual/degraded mode.
ANTHROPIC_API_KEY=

# Optional — defaults to claude-sonnet-5 if not set (and no override is saved in Settings).
ANTHROPIC_MODEL=claude-sonnet-5

# Google Sheets — used as the database for the Settings page (currently: the AI key/model).
# 1. Create/choose a Google Cloud project, enable the "Google Sheets API".
# 2. Create a Service Account, generate a JSON key — its "client_email" and "private_key" go below.
# 3. Create a Google Sheet (any name) and share it with that client_email as Editor.
# 4. Copy the spreadsheet ID from its URL (the long string between /d/ and /edit).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
